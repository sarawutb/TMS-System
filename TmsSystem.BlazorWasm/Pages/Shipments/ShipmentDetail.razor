@page "/shipments/{Id:long}"
@attribute [Authorize]
@inject ShipmentDetailViewModel ViewModel

<PageTitle>Shipment Detail - TMS Control Room</PageTitle>

<div class="tms-content">
    <div class="d-flex align-items-center mb-4">
        <button class="btn btn-sm btn-outline-secondary me-3 px-3 py-1" style="border-radius: 6px;" @onclick="ViewModel.BackToList">
            <i class="bi bi-chevron-left me-1"></i> BACK
        </button>
        <div>
            <h4 class="fw-bold text-gray-900 m-0">Shipment: @(ViewModel.Shipment?.ShipmentNo ?? Id.ToString())</h4>
            <p class="text-muted small m-0">Tracking information and dispatch resources</p>
        </div>
    </div>

    @if (ViewModel.IsLoading)
    {
        <div class="tms-card text-center p-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted mt-2 small">Loading shipment details...</p>
        </div>
    }
    else if (ViewModel.Shipment is null)
    {
        <div class="tms-card text-center p-5">
            <i class="bi bi-exclamation-triangle fs-1 text-danger"></i>
            <h5 class="mt-3 fw-semibold text-gray-800">Shipment Not Found</h5>
            <p class="text-muted small">The shipment ID may be invalid or it has been deleted.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Left Column: Core Fields -->
            <div class="col-lg-8 col-md-12">
                <div class="tms-card mb-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">
                        <i class="bi bi-info-circle me-2 text-primary"></i>Shipment Properties
                    </h5>

                    <div class="row g-4">
                        <div class="col-md-6 col-sm-12">
                            <label class="form-label text-muted small fw-semibold d-block">SHIPMENT NUMBER</label>
                            <span class="fw-bold text-gray-900 fs-5">@ViewModel.Shipment.ShipmentNo</span>
                        </div>
                        <div class="col-md-6 col-sm-12">
                            <label class="form-label text-muted small fw-semibold d-block">STATUS</label>
                            <span class="tms-badge @ViewModel.GetStatusBadgeClass(ViewModel.Shipment.ShipmentStatus)">@ViewModel.Shipment.ShipmentStatus</span>
                        </div>

                        <div class="col-md-6 col-sm-12">
                            <label class="form-label text-muted small fw-semibold d-block">TRANSPORT ORDER REF</label>
                            @if (ViewModel.Shipment.TransportOrderId.HasValue)
                            {
                                <a href="transport-orders/@ViewModel.Shipment.TransportOrderId" class="fw-bold text-primary fs-6">
                                    @ViewModel.OrderNo
                                </a>
                            }
                            else
                            {
                                <span class="text-muted small">No Order Reference</span>
                            }
                        </div>
                        <div class="col-md-6 col-sm-12">
                            <label class="form-label text-muted small fw-semibold d-block">LATEST ETA</label>
                            <span class="text-gray-800 fw-semibold">
                                <i class="bi bi-clock me-1 text-muted"></i>
                                @(ViewModel.Shipment.LatestEta?.ToString("yyyy-MM-dd HH:mm") ?? "-")
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Timestamps Card -->
                <div class="tms-card">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">
                        <i class="bi bi-calendar-check me-2 text-primary"></i>Schedule & Delivery Log
                    </h5>

                    <div class="row g-4">
                        <!-- Pickup timelines -->
                        <div class="col-md-6 col-sm-12 border-end">
                            <h6 class="fw-bold text-gray-900 mb-3"><i class="bi bi-box-arrow-in-up me-2 text-muted"></i>Pickup Milestones</h6>
                            
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-semibold d-block mb-1">PLANNED PICKUP</label>
                                <span class="text-gray-800 small">@(ViewModel.Shipment.PlannedPickupDate?.ToString("yyyy-MM-dd HH:mm") ?? "-")</span>
                            </div>
                            <div>
                                <label class="form-label text-muted small fw-semibold d-block mb-1">ACTUAL PICKUP</label>
                                <span class="text-gray-800 small">
                                    @if (ViewModel.Shipment.ActualPickupDate.HasValue)
                                    {
                                        <span class="text-success fw-medium">
                                            <i class="bi bi-check-circle me-1"></i> @ViewModel.Shipment.ActualPickupDate.Value.ToString("yyyy-MM-dd HH:mm")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Pending Dispatch</span>
                                    }
                                </span>
                            </div>
                        </div>

                        <!-- Delivery timelines -->
                        <div class="col-md-6 col-sm-12">
                            <h6 class="fw-bold text-gray-900 mb-3"><i class="bi bi-box-arrow-down me-2 text-muted"></i>Delivery Milestones</h6>

                            <div class="mb-3">
                                <label class="form-label text-muted small fw-semibold d-block mb-1">PLANNED DELIVERY</label>
                                <span class="text-gray-800 small">@(ViewModel.Shipment.PlannedDeliveryDate?.ToString("yyyy-MM-dd HH:mm") ?? "-")</span>
                            </div>
                            <div>
                                <label class="form-label text-muted small fw-semibold d-block mb-1">ACTUAL DELIVERY</label>
                                <span class="text-gray-800 small">
                                    @if (ViewModel.Shipment.ActualDeliveryDate.HasValue)
                                    {
                                        <span class="text-success fw-medium">
                                            <i class="bi bi-check-circle me-1"></i> @ViewModel.Shipment.ActualDeliveryDate.Value.ToString("yyyy-MM-dd HH:mm")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Pending Delivery</span>
                                    }
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Dispatch Details -->
            <div class="col-lg-4 col-md-12">
                <!-- Vehicle/Driver/Carrier -->
                <div class="tms-card">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">
                        <i class="bi bi-truck me-2 text-primary"></i>Logistics Dispatch
                    </h5>

                    <div class="mb-4">
                        <label class="form-label text-muted small fw-semibold d-block mb-1">CARRIER</label>
                        <div class="d-flex align-items-center">
                            <div class="bg-light p-2 rounded me-3 text-muted">
                                <i class="bi bi-building fs-4"></i>
                            </div>
                            <div>
                                <h6 class="m-0 fw-bold text-gray-800">@ViewModel.CarrierName</h6>
                                <span class="text-muted small">Carrier ID: @(ViewModel.Shipment.CarrierId?.ToString() ?? "-")</span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted small fw-semibold d-block mb-1">VEHICLE ASSIGNED</label>
                        <div class="d-flex align-items-center">
                            <div class="bg-light p-2 rounded me-3 text-muted">
                                <i class="bi bi-truck-flatbed fs-4"></i>
                            </div>
                            <div>
                                <h6 class="m-0 fw-bold text-gray-800">@ViewModel.VehiclePlate</h6>
                                <span class="text-muted small">Type: @ViewModel.VehicleType</span>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="form-label text-muted small fw-semibold d-block mb-1">DRIVER ASSIGNED</label>
                        <div class="d-flex align-items-center">
                            <div class="bg-light p-2 rounded me-3 text-muted">
                                <i class="bi bi-person-badge fs-4"></i>
                            </div>
                            <div>
                                <h6 class="m-0 fw-bold text-gray-800">@ViewModel.DriverName</h6>
                                <span class="text-muted small">Driver ID: @(ViewModel.Shipment.DriverId?.ToString() ?? "-")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public long Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await ViewModel.InitializeAsync(Id);
    }
}
