@page "/transport-orders/{Id:long}"
@attribute [Authorize]
@inject OrderDetailViewModel ViewModel

<PageTitle>Transport Order Detail - TMS Control Room</PageTitle>

<div class="tms-content">
    <div class="d-flex align-items-center mb-4">
        <button class="btn btn-sm btn-outline-secondary me-3 px-3 py-1" style="border-radius: 6px;" @onclick="ViewModel.BackToList">
            <i class="bi bi-chevron-left me-1"></i> BACK
        </button>
        <div>
            <h4 class="fw-bold text-gray-900 m-0">Order: @(ViewModel.Order?.TransportOrderNo ?? Id.ToString())</h4>
            <p class="text-muted small m-0">Detailed view and management of this transport order</p>
        </div>
    </div>

    @if (ViewModel.IsLoading)
    {
        <div class="tms-card text-center p-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted mt-2 small">Loading order details...</p>
        </div>
    }
    else if (ViewModel.Order is null)
    {
        <div class="tms-card text-center p-5">
            <i class="bi bi-exclamation-triangle fs-1 text-danger"></i>
            <h5 class="mt-3 fw-semibold text-gray-800">Order Not Found</h5>
            <p class="text-muted small">The transport order ID may be invalid or it has been deleted.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Left Column: Core Fields -->
            <div class="col-lg-8 col-md-12">
                <div class="tms-card mb-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">
                        <i class="bi bi-card-text me-2 text-primary"></i>General Information
                    </h5>
                    
                    <div class="row g-4">
                        <div class="col-md-6 col-sm-12">
                            <label class="form-label text-muted small fw-semibold d-block">ORDER NUMBER</label>
                            <span class="fw-bold text-gray-900 fs-5">@ViewModel.Order.TransportOrderNo</span>
                        </div>
                        <div class="col-md-6 col-sm-12">
                            <label class="form-label text-muted small fw-semibold d-block">STATUS</label>
                            <span class="tms-badge @ViewModel.GetStatusBadgeClass(ViewModel.Order.Status)">@ViewModel.Order.Status</span>
                        </div>
                        
                        <div class="col-md-6 col-sm-12">
                            <label class="form-label text-muted small fw-semibold d-block">PRIORITY</label>
                            <span class="tms-badge @ViewModel.GetPriorityBadgeClass(ViewModel.Order.Priority)">@ViewModel.Order.Priority</span>
                        </div>
                        <div class="col-md-6 col-sm-12">
                            <label class="form-label text-muted small fw-semibold d-block">TEMPERATURE REQ.</label>
                            @if (ViewModel.Order.TemperatureRequired)
                            {
                                <span class="tms-badge tms-badge-danger"><i class="bi bi-thermometer-half"></i> Temperature Controlled</span>
                            }
                            else
                            {
                                <span class="text-muted small">Standard Cargo (Ambient)</span>
                            }
                        </div>

                        <div class="col-md-6 col-sm-12">
                            <label class="form-label text-muted small fw-semibold d-block">SOURCE SYSTEM</label>
                            <span class="text-gray-800 fw-medium">@ViewModel.Order.SourceSystem</span>
                        </div>
                        <div class="col-md-6 col-sm-12">
                            <label class="form-label text-muted small fw-semibold d-block">SOURCE DOC NO</label>
                            <span class="text-gray-800 fw-medium">@(string.IsNullOrWhiteSpace(ViewModel.Order.SourceDocumentNo) ? "-" : ViewModel.Order.SourceDocumentNo)</span>
                        </div>
                    </div>
                </div>

                <!-- Locations Card -->
                <div class="tms-card">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">
                        <i class="bi bi-geo-alt me-2 text-primary"></i>Route & Locations
                    </h5>

                    <div class="row g-4">
                        <!-- Origin Location -->
                        <div class="col-md-6 col-sm-12 border-end">
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px; font-size: 11px;">
                                    A
                                </div>
                                <span class="text-muted small fw-semibold">PICKUP LOCATION</span>
                            </div>
                            <h6 class="fw-bold text-gray-900 mb-1">@ViewModel.PickupName</h6>
                            <span class="text-muted small d-block">Code: @ViewModel.PickupCode</span>
                            <span class="text-muted small d-block mt-2">@ViewModel.PickupAddress</span>
                            
                            <div class="mt-3">
                                <label class="form-label text-muted small fw-semibold d-block mb-1">REQUESTED PICKUP DATE</label>
                                <span class="text-gray-800 fw-medium small">
                                    <i class="bi bi-calendar-event me-1 text-muted"></i>
                                    @(ViewModel.Order.RequestedPickupDate?.ToString("yyyy-MM-dd HH:mm") ?? "Anytime")
                                </span>
                            </div>
                        </div>

                        <!-- Destination Location -->
                        <div class="col-md-6 col-sm-12">
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px; font-size: 11px;">
                                    B
                                </div>
                                <span class="text-muted small fw-semibold">DELIVERY LOCATION</span>
                            </div>
                            <h6 class="fw-bold text-gray-900 mb-1">@ViewModel.DeliveryName</h6>
                            <span class="text-muted small d-block">Code: @ViewModel.DeliveryCode</span>
                            <span class="text-muted small d-block mt-2">@ViewModel.DeliveryAddress</span>

                            <div class="mt-3">
                                <label class="form-label text-muted small fw-semibold d-block mb-1">REQUESTED DELIVERY DATE</label>
                                <span class="text-gray-800 fw-medium small">
                                    <i class="bi bi-calendar-event me-1 text-muted"></i>
                                    @(ViewModel.Order.RequestedDeliveryDate?.ToString("yyyy-MM-dd HH:mm") ?? "Anytime")
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Business Entities & Actions -->
            <div class="col-lg-4 col-md-12">
                <!-- Entities Card -->
                <div class="tms-card mb-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">
                        <i class="bi bi-building me-2 text-primary"></i>Parties Involved
                    </h5>
                    
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-semibold d-block mb-1">FACTORY / SITE</label>
                        <div class="d-flex align-items-center">
                            <div class="bg-light p-2 rounded me-3 text-muted">
                                <i class="bi bi-house-door fs-4"></i>
                            </div>
                            <div>
                                <h6 class="m-0 fw-bold text-gray-800">@ViewModel.FactoryName</h6>
                                <span class="text-muted small">Code: @ViewModel.FactoryCode</span>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="form-label text-muted small fw-semibold d-block mb-1">CUSTOMER / PARTNER</label>
                        <div class="d-flex align-items-center">
                            <div class="bg-light p-2 rounded me-3 text-muted">
                                <i class="bi bi-person-badge fs-4"></i>
                            </div>
                            <div>
                                <h6 class="m-0 fw-bold text-gray-800">@ViewModel.CustomerName</h6>
                                <span class="text-muted small">Code: @ViewModel.CustomerCode</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Actions Card -->
                <div class="tms-card">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">
                        <i class="bi bi-sliders me-2 text-primary"></i>Control Panel
                    </h5>

                    <button class="btn btn-outline-primary w-100 fw-semibold mb-3 py-2" style="border-radius: 6px;" @onclick="() => ViewModel.EditOrder(Id)">
                        <i class="bi bi-pencil me-2"></i>EDIT ORDER
                    </button>
                    <button class="btn btn-danger w-100 fw-semibold py-2" style="border-radius: 6px;" @onclick="ViewModel.ConfirmDelete">
                        <i class="bi bi-trash me-2"></i>DELETE ORDER
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<!-- Delete Confirmation Modal -->
@if (ViewModel.ShowDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow" style="border-radius: 8px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold text-danger">Delete Transport Order</h5>
                    <button type="button" class="btn-close" @onclick="ViewModel.CloseDeleteModal"></button>
                </div>
                <div class="modal-body py-3">
                    <p class="m-0">Are you sure you want to delete this order? This action cannot be undone.</p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light fw-semibold" style="border-radius: 6px;" @onclick="ViewModel.CloseDeleteModal">Cancel</button>
                    <button type="button" class="btn btn-danger fw-semibold" style="border-radius: 6px;" @onclick="() => ViewModel.ExecuteDeleteAsync(Id)">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public long Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await ViewModel.InitializeAsync(Id);
    }
}
