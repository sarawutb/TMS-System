@page "/master-data/{EntityKey}/new"
@page "/master-data/{EntityKey}/{Id:long}/edit"
@attribute [Authorize]
@inject MasterDataFormViewModel ViewModel

<PageTitle>@(Id.HasValue ? "Edit" : "New") @ViewModel.SelectedDefinition.Title - Master Data</PageTitle>

<div class="tms-content">
    <div class="d-flex align-items-center mb-4">
        <button class="btn btn-sm btn-outline-secondary me-3 px-3 py-1" style="border-radius: 6px;" @onclick="ViewModel.Cancel">
            <i class="bi bi-chevron-left me-1"></i> BACK
        </button>
        <div>
            <h4 class="fw-bold text-gray-900 m-0">@(Id.HasValue ? $"Edit {ViewModel.SelectedDefinition.Title}" : $"New {ViewModel.SelectedDefinition.Title}")</h4>
            <p class="text-muted small m-0">@ViewModel.SelectedDefinition.Description</p>
        </div>
    </div>

    @if (ViewModel.IsLoading)
    {
        <div class="tms-card text-center p-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted mt-2 small">Loading setup form...</p>
        </div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
        {
            <div class="alert alert-danger py-2 px-3 small border-0 mb-4" style="border-radius: 6px;">
                <i class="bi bi-exclamation-circle-fill me-2"></i>@ViewModel.ErrorMessage
            </div>
        }

        <div class="tms-card">
            <form @onsubmit="SaveAsync" @onsubmit:preventDefault>
                <div class="master-data-form-grid">
                    @foreach (var field in ViewModel.SelectedDefinition.FormFields)
                    {
                        <div class="master-data-field @(field.FieldType == MasterDataFieldType.Checkbox ? "master-data-field-check" : string.Empty)">
                            @if (field.FieldType == MasterDataFieldType.Checkbox)
                            {
                                <div class="form-check form-switch mt-4">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="@field.Name"
                                           checked="@ViewModel.GetBoolValue(field)"
                                           @onchange="async e => await ViewModel.SetCheckboxValueAsync(field, e.Value is bool checkedValue && checkedValue)" />
                                    <label class="form-check-label fw-semibold text-muted small" for="@field.Name">@field.Label.ToUpperInvariant()</label>
                                </div>
                            }
                            else
                            {
                                <label class="form-label text-muted small fw-semibold">
                                    @field.Label.ToUpperInvariant()
                                    @if (field.Required)
                                    {
                                        <span class="text-danger">*</span>
                                    }
                                </label>

                                @if (field.FieldType == MasterDataFieldType.Select)
                                {
                                    <select class="form-select"
                                            style="border-radius: 6px;"
                                            value="@ViewModel.GetFieldText(field)"
                                            @onchange="async e => await ViewModel.SetFieldValueAsync(field, e.Value?.ToString())">
                                        <option value="">-- Select @field.Label --</option>
                                        @foreach (var option in ViewModel.GetOptions(field))
                                        {
                                            <option value="@option.Value">@option.Label</option>
                                        }
                                    </select>
                                }
                                else if (field.FieldType == MasterDataFieldType.Decimal)
                                {
                                    <input type="number"
                                           step="0.01"
                                           class="form-control"
                                           style="border-radius: 6px;"
                                           value="@ViewModel.GetFieldText(field)"
                                           @onchange="async e => await ViewModel.SetFieldValueAsync(field, e.Value?.ToString())" />
                                }
                                else
                                {
                                    <input type="text"
                                           class="form-control"
                                           style="border-radius: 6px;"
                                           value="@ViewModel.GetFieldText(field)"
                                           @onchange="async e => await ViewModel.SetFieldValueAsync(field, e.Value?.ToString())" />
                                }
                            }
                        </div>
                    }
                </div>

                <div class="border-top pt-4 mt-4 text-end">
                    <button type="button" class="btn btn-light fw-semibold px-4 me-2" style="border-radius: 6px; height: 40px;" @onclick="ViewModel.Cancel">
                        CANCEL
                    </button>
                    <button type="submit" class="btn btn-primary fw-semibold px-4" style="border-radius: 6px; height: 40px;" disabled="@ViewModel.IsSaving">
                        @if (ViewModel.IsSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>SAVING...</span>
                        }
                        else
                        {
                            <span>SAVE</span>
                        }
                    </button>
                </div>
            </form>
        </div>
    }
</div>

@code {
    [Parameter] public string? EntityKey { get; set; }
    [Parameter] public long? Id { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await ViewModel.InitializeAsync(EntityKey, Id);
    }

    private async Task SaveAsync()
    {
        await ViewModel.SaveAsync(Id);
    }
}
