@inject NavigationManager NavigationManager

<div class="tms-sidebar-brand">
    <i class="bi bi-truck-flatbed me-2"></i>
    <span>TMS CONTROL ROOM</span>
</div>

<div class="tms-sidebar-menu">
    <NavLink class="tms-menu-item" href="" Match="NavLinkMatch.All">
        <i class="bi bi-speedometer2"></i> Control Tower
    </NavLink>
    <NavLink class="tms-menu-item" href="transport-orders">
        <i class="bi bi-file-earmark-text"></i> Transport Orders
    </NavLink>
    <NavLink class="tms-menu-item" href="shipments">
        <i class="bi bi-signpost-split"></i> Shipments
    </NavLink>
    <div class="tms-menu-group">
        <button class="tms-menu-item tms-menu-toggle @(IsPlanningActive ? "active" : null)" type="button" @onclick="TogglePlanningMenu" aria-expanded="@isPlanningOpen">
            <span class="tms-menu-toggle-label">
                <i class="bi bi-diagram-3"></i>
                <span>Planning</span>
            </span>
            <i class="bi bi-chevron-down tms-menu-toggle-icon @(isPlanningOpen ? "open" : null)"></i>
        </button>
        @if (isPlanningOpen)
        {
            <div class="tms-submenu">
                <NavLink class="tms-submenu-item" href="planning" Match="NavLinkMatch.All">
                    <i class="bi bi-columns-gap"></i>
                    <span>Workbench</span>
                </NavLink>
            </div>
        }
    </div>
    <div class="tms-menu-group">
        <button class="tms-menu-item tms-menu-toggle @(IsMasterDataActive ? "active" : null)" type="button" @onclick="ToggleMasterDataMenu" aria-expanded="@isMasterDataOpen">
            <span class="tms-menu-toggle-label">
                <i class="bi bi-database-gear"></i>
                <span>Master Data</span>
            </span>
            <i class="bi bi-chevron-down tms-menu-toggle-icon @(isMasterDataOpen ? "open" : null)"></i>
        </button>
        @if (isMasterDataOpen)
        {
            <div class="tms-submenu">
                @foreach (var definition in MasterDataDefinitions.All)
                {
                    <NavLink class="tms-submenu-item" href="@($"master-data/{definition.Key}")">
                        <i class="@definition.IconCss"></i>
                        <span>@definition.Title</span>
                    </NavLink>
                }
            </div>
        }
    </div>
    <NavLink class="tms-menu-item" href="exceptions">
        <i class="bi bi-exclamation-triangle"></i> Exceptions
    </NavLink>
    <NavLink class="tms-menu-item" href="fleet">
        <i class="bi bi-car-front"></i> Fleet & Drivers
    </NavLink>
    <NavLink class="tms-menu-item" href="billing">
        <i class="bi bi-receipt"></i> Freight & Invoices
    </NavLink>
    <NavLink class="tms-menu-item" href="integration">
        <i class="bi bi-hdd-network"></i> Integration Partner
    </NavLink>
    <NavLink class="tms-menu-item" href="users">
        <i class="bi bi-people"></i> User Management
    </NavLink>
</div>

@code {
    private bool isPlanningOpen;
    private bool isMasterDataOpen;

    private bool IsPlanningActive => NavigationManager.ToBaseRelativePath(NavigationManager.Uri)
        .StartsWith("planning", StringComparison.OrdinalIgnoreCase);

    private bool IsMasterDataActive => NavigationManager.ToBaseRelativePath(NavigationManager.Uri)
        .StartsWith("master-data", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        isPlanningOpen = IsPlanningActive;
        isMasterDataOpen = IsMasterDataActive;
    }

    private void TogglePlanningMenu()
    {
        isPlanningOpen = !isPlanningOpen;
    }

    private void ToggleMasterDataMenu()
    {
        isMasterDataOpen = !isMasterDataOpen;
    }
}
